---
import PageLayout from "@/layouts/PageLayout.astro"
import EpisodeList from "@/components/episode-list/EpisodeList.vue"
---

<PageLayout>
	<div class="c-home-content-container">
		<div class="c-home-about mt-4">
			<h2 class="c-home-title mb-1">About the show</h2>
			<p>
				okTurtles Podcast explores all the latest decentralization technologies, with a focus on security and privacy.
			</p>
		</div>

		<hr class="section-divider is-full-width c-section-divider" />

		<EpisodeList client:load listTitle='Episodes' />
	</div>
</PageLayout>

<style lang="scss">
@use '@/styles/variables' as *;

.c-home-content-container {
  position: relative;
  display: block;
  margin: 0 auto;
	padding-bottom: 7rem;

	@include from($tablet) {
		padding-bottom: 10rem;
	}
}

.c-section-divider {
	margin-top: 3rem;
	margin-bottom: 3rem;
	
	@include from($tablet) {
		margin-top: 4rem;
		margin-bottom: 4rem;
	}
}

.c-home-title {
	font-size: $font-lg;

	@include from($tablet) {
		font-size: $font-heading-5;
	}
}
</style>
